# ============================================================
# Bobrito Trading Bot — Environment Configuration Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Runtime Mode ─────────────────────────────────────────────
# Options: paper | testnet | live
BOT_MODE=paper

# ── Binance API Keys (Testnet) ────────────────────────────────
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# ── Binance API Keys (Live) ───────────────────────────────────
# Only used when BOT_MODE=live AND LIVE_TRADING_ENABLED=true
BINANCE_LIVE_API_KEY=your_live_api_key_here
BINANCE_LIVE_API_SECRET=your_live_api_secret_here

# ── Live Trading Safety Gate ──────────────────────────────────
# Must be explicitly set to "true" to allow live orders
LIVE_TRADING_ENABLED=false

# ── Capital ───────────────────────────────────────────────────
INITIAL_CAPITAL_USDT=200.0
PAPER_INITIAL_USDT=200.0

# ── Exchange Filters (v1.3) ───────────────────────────────────
# When exchangeInfo is unavailable: false = fail (live/testnet) or safe-mode (paper)
# true = use fallback values below (NOT recommended for live trading)
ALLOW_FILTER_FALLBACK=false
# Fallback values used when ALLOW_FILTER_FALLBACK=true or paper safe-mode
FALLBACK_STEP_SIZE=0.00001
FALLBACK_MIN_QTY=0.00001
FALLBACK_MIN_NOTIONAL=5.0
FALLBACK_TICK_SIZE=0.01

# ── Strategy Parameters ───────────────────────────────────────
EMA_FAST=9
EMA_SLOW=21
ATR_PERIOD=14
VOLUME_MULTIPLIER=1.5
# Newly externalised (v1.3)
EMA_MIN_SEPARATION_PCT=0.05
PULLBACK_LOOKBACK_BARS=5
PULLBACK_NEAR_SLOW_EMA_PCT=0.2
VOLUME_SMA_PERIOD=20
STOP_ATR_MULTIPLIER=1.5
TARGET_ATR_MULTIPLIER=3.0
MIN_1M_WARMUP_CANDLES=30
MIN_5M_WARMUP_CANDLES=25
SWING_LOW_LOOKBACK=5

# ── Fee-aware Entry Filter (v1.3) ─────────────────────────────
# Reject entries when target distance or net edge after fees is too small
MIN_EXPECTED_EDGE_ENABLED=true
ESTIMATED_ROUNDTRIP_FEE_BPS=20.0
ESTIMATED_ROUNDTRIP_SLIPPAGE_BPS=10.0
MIN_EXPECTED_NET_EDGE_BPS=15.0
MIN_TARGET_DISTANCE_BPS=45.0

# ── Momentum Failure Exit (v1.3) ───────────────────────────────
# Exit only after min_hold_bars AND consecutive_below >= confirm_bars
MOMENTUM_FAILURE_CONFIRM_BARS=2
MOMENTUM_FAILURE_MIN_HOLD_BARS=2
MOMENTUM_FAILURE_EXIT_EMA=fast

# ── Risk Parameters ───────────────────────────────────────────
RISK_PER_TRADE_PCT=0.75
MAX_DAILY_LOSS_PCT=3.0
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_MINUTES_AFTER_LOSSES=60
MAX_TRADES_PER_DAY=10
MIN_FREE_BALANCE_USDT=20.0

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/bobrito.db

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=change_me_to_a_random_secret_at_least_32_chars

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/bobrito.log

# ── Web UI ────────────────────────────────────────────────────
# The embedded operator dashboard is DISABLED by default.
# To enable: set WEB_UI_ENABLED=true and configure the three
# credentials below, then open http://localhost:8080/ui
#
# Quick start:
#   1. Set WEB_UI_ENABLED=true
#   2. Set a strong WEB_UI_PASSWORD and WEB_UI_SESSION_SECRET
#   3. Start the bot: python -m bobrito.main
#   4. Open http://localhost:8080/ui and log in

# Enable or disable the web interface entirely
WEB_UI_ENABLED=false

# URL prefix for all UI routes (default: /ui)
WEB_UI_ROUTE_PREFIX=/ui

# Login credentials for the operator dashboard
# Change these before exposing the bot on any network
WEB_UI_USERNAME=admin
WEB_UI_PASSWORD=change_me_strong_password

# Secret used to sign session cookies — must be at least 32 characters.
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
WEB_UI_SESSION_SECRET=change_me_very_long_random_secret_32chars

# How often (seconds) the dashboard auto-refreshes live data via HTMX polling
WEB_UI_PAGE_REFRESH_SECONDS=5

# Set to true to show the dashboard but disable all control buttons
WEB_UI_READONLY=false

# Control which actions are available in the UI
WEB_UI_ALLOW_START_STOP=true
WEB_UI_ALLOW_EMERGENCY_STOP=true

# Require an explicit confirmation dialog before executing actions in live mode
WEB_UI_CONFIRM_LIVE_ACTIONS=true
