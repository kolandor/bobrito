# ============================================================
# Bobrito Trading Bot — Environment Configuration Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Runtime Mode ─────────────────────────────────────────────
# Options: paper | testnet | live
BOT_MODE=paper

# ── Binance API Keys (Testnet) ────────────────────────────────
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# ── Binance API Keys (Live) ───────────────────────────────────
# Only used when BOT_MODE=live AND LIVE_TRADING_ENABLED=true
BINANCE_LIVE_API_KEY=your_live_api_key_here
BINANCE_LIVE_API_SECRET=your_live_api_secret_here

# ── Live Trading Safety Gate ──────────────────────────────────
# Must be explicitly set to "true" to allow live orders
LIVE_TRADING_ENABLED=false

# ── Capital ───────────────────────────────────────────────────
INITIAL_CAPITAL_USDT=200.0
PAPER_INITIAL_USDT=200.0

# ── Strategy Parameters ───────────────────────────────────────
EMA_FAST=9
EMA_SLOW=21
ATR_PERIOD=14
VOLUME_MULTIPLIER=1.5

# ── Risk Parameters ───────────────────────────────────────────
RISK_PER_TRADE_PCT=0.75
MAX_DAILY_LOSS_PCT=3.0
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_MINUTES_AFTER_LOSSES=60
MAX_TRADES_PER_DAY=10
MIN_FREE_BALANCE_USDT=20.0

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/bobrito.db

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=change_me_to_a_random_secret_at_least_32_chars

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/bobrito.log
