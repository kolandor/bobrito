# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# ── Source tree cache artifacts ───────────────────────────────────────────────
src/**/__pycache__/
tests/**/__pycache__/

# ── Build / distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
sdist/
pip-wheel-metadata/
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite3
data/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Test & coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# ── Type checkers & linters ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pyre/

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── IDEs & editors ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Alembic generated (keep versions tracked) ────────────────────────────────
# alembic/versions/ is intentionally tracked
